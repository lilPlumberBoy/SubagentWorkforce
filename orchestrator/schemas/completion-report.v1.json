{
  "type": "object",
  "required": [
    "schema",
    "run_id",
    "phase",
    "objective_id",
    "task_id",
    "agent_role",
    "status",
    "summary",
    "artifacts",
    "validation_results",
    "open_issues",
    "produced_outputs",
    "change_requests"
  ],
  "additionalProperties": true,
  "properties": {
    "schema": {"type": "string", "enum": ["completion-report.v1"]},
    "run_id": {"type": "string"},
    "phase": {"type": "string", "enum": ["discovery", "design", "mvp-build", "polish"]},
    "objective_id": {"type": "string"},
    "task_id": {"type": "string"},
    "agent_role": {"type": "string"},
    "status": {"type": "string", "enum": ["ready_for_bundle_review", "blocked", "needs_revision"]},
    "summary": {"type": "string"},
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "status"],
        "additionalProperties": false,
        "properties": {
          "path": {"type": "string"},
          "status": {"type": "string"}
        }
      }
    },
    "validation_results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "status", "evidence"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string"},
          "status": {"type": "string", "enum": ["passed", "failed"]},
          "evidence": {"type": "string"}
        }
      }
    },
    "open_issues": {"type": "array", "items": {"type": "string"}},
    "change_requests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "schema",
          "run_id",
          "change_id",
          "source_task_id",
          "source_objective_id",
          "phase",
          "change_category",
          "summary",
          "blocking_reason",
          "why_local_resolution_is_invalid",
          "blocking",
          "goal_critical",
          "affected_output_ids",
          "affected_handoff_ids",
          "impacted_objective_ids",
          "impacted_task_ids",
          "required_reentry_phase",
          "impact",
          "approval",
          "replacement_plan_revision"
        ],
        "additionalProperties": false,
        "properties": {
          "schema": {"type": "string", "enum": ["change-request.v2"]},
          "run_id": {"type": "string"},
          "change_id": {"type": "string"},
          "source_task_id": {"type": "string"},
          "source_objective_id": {"type": "string"},
          "phase": {"type": "string", "enum": ["discovery", "design", "mvp-build", "polish"]},
          "change_category": {
            "type": "string",
            "enum": ["interface_contract", "shared_behavior", "ownership_boundary", "acceptance_rule"]
          },
          "summary": {"type": "string"},
          "blocking_reason": {"type": "string"},
          "why_local_resolution_is_invalid": {"type": "string"},
          "blocking": {"type": "boolean"},
          "goal_critical": {"type": "boolean"},
          "affected_output_ids": {"type": "array", "items": {"type": "string"}},
          "affected_handoff_ids": {"type": "array", "items": {"type": "string"}},
          "impacted_objective_ids": {"type": "array", "items": {"type": "string"}},
          "impacted_task_ids": {"type": "array", "items": {"type": "string"}},
          "required_reentry_phase": {"type": "string", "enum": ["discovery", "design", "mvp-build", "polish"]},
          "impact": {
            "type": "object",
            "required": [
              "goal_changed",
              "scope_changed",
              "boundary_changed",
              "interface_changed",
              "architecture_changed",
              "team_changed",
              "implementation_changed"
            ],
            "additionalProperties": false,
            "properties": {
              "goal_changed": {"type": "boolean"},
              "scope_changed": {"type": "boolean"},
              "boundary_changed": {"type": "boolean"},
              "interface_changed": {"type": "boolean"},
              "architecture_changed": {"type": "boolean"},
              "team_changed": {"type": "boolean"},
              "implementation_changed": {"type": "boolean"}
            }
          },
          "approval": {
            "type": "object",
            "required": ["mode", "status"],
            "additionalProperties": false,
            "properties": {
              "mode": {"type": "string", "enum": ["auto", "human"]},
              "status": {"type": "string", "enum": ["approved", "pending_human_review"]}
            }
          },
          "replacement_plan_revision": {"type": ["string", "null"]}
        }
      }
    },
    "produced_outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "output_id", "path", "asset_id", "description", "evidence"],
        "additionalProperties": false,
        "properties": {
          "kind": {"type": "string", "enum": ["artifact", "asset", "assertion"]},
          "output_id": {"type": "string"},
          "path": {"type": ["string", "null"]},
          "asset_id": {"type": ["string", "null"]},
          "description": {"type": ["string", "null"]},
          "evidence": {
            "type": ["object", "null"],
            "required": ["validation_ids", "artifact_paths"],
            "additionalProperties": false,
            "properties": {
              "validation_ids": {"type": "array", "items": {"type": "string"}},
              "artifact_paths": {"type": "array", "items": {"type": "string"}}
            }
          }
        }
      }
    },
    "runtime_warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "message"],
        "additionalProperties": false,
        "properties": {
          "code": {"type": "string"},
          "message": {"type": "string"}
        }
      }
    },
    "runtime_recovery": {
      "type": "object",
      "required": ["attempt", "recovery_action", "workspace_reused", "timeout_retries_used"],
      "additionalProperties": false,
      "properties": {
        "attempt": {"type": "number"},
        "recovery_action": {"type": ["string", "null"]},
        "workspace_reused": {"type": "boolean"},
        "timeout_retries_used": {"type": "number"}
      }
    },
    "runtime_observability": {
      "type": "object",
      "required": [
        "prompt_char_count",
        "prompt_line_count",
        "prompt_bytes",
        "queue_wait_ms",
        "runtime_ms",
        "last_call_latency_ms",
        "llm_call_count",
        "timeout_count",
        "timeout_retry_count",
        "input_tokens",
        "cached_input_tokens",
        "output_tokens",
        "stdout_bytes",
        "stderr_bytes"
      ],
      "additionalProperties": false,
      "properties": {
        "prompt_char_count": {"type": "number"},
        "prompt_line_count": {"type": "number"},
        "prompt_bytes": {"type": "number"},
        "queue_wait_ms": {"type": "number"},
        "runtime_ms": {"type": "number"},
        "last_call_latency_ms": {"type": "number"},
        "llm_call_count": {"type": "number"},
        "timeout_count": {"type": "number"},
        "timeout_retry_count": {"type": "number"},
        "input_tokens": {"type": "number"},
        "cached_input_tokens": {"type": "number"},
        "output_tokens": {"type": "number"},
        "stdout_bytes": {"type": "number"},
        "stderr_bytes": {"type": "number"}
      }
    },
    "context_echo": {
      "type": "object",
      "required": ["role_id", "objective_id", "phase", "prompt_layers", "schema"],
      "additionalProperties": false,
      "properties": {
        "role_id": {"type": "string"},
        "objective_id": {"type": "string"},
        "phase": {"type": "string"},
        "prompt_layers": {"type": "array", "items": {"type": "string"}},
        "schema": {"type": "string"}
      }
    }
  }
}
