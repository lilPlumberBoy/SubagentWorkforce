{
  "type": "object",
  "required": ["schema", "run_id", "teams"],
  "additionalProperties": false,
  "properties": {
    "schema": {"type": "string", "enum": ["team-registry.v1"]},
    "run_id": {"type": "string"},
    "teams": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["objective_id", "team_id", "status", "capabilities", "roles"],
        "additionalProperties": false,
        "properties": {
          "objective_id": {"type": "string"},
          "team_id": {"type": "string"},
          "status": {"type": "string", "enum": ["proposed", "approved", "active"]},
          "capabilities": {
            "type": "array",
            "items": {"type": "string"}
          },
          "roles": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["role_id", "role_kind"],
              "additionalProperties": true,
              "properties": {
                "role_id": {"type": "string"},
                "role_kind": {"type": "string", "enum": ["manager", "worker", "acceptance-manager"]},
                "capability": {"type": "string"}
              }
            }
          }
        }
      }
    }
  }
}
