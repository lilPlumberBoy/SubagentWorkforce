  "additionalProperties": false,
  "properties": {
    "schema": {"type": "string", "enum": ["activity-live-state.v1"]},
    "run_id": {"type": "string"},
    "activity_id": {"type": "string"},
    "kind": {"type": "string", "enum": ["task_execution", "objective_plan", "capability_plan"]},
    "entity_id": {"type": "string"},
    "phase": {"type": "string", "enum": ["discovery", "design", "mvp-build", "polish"]},
    "objective_id": {"type": "string"},
    "display_name": {"type": "string"},
    "assigned_role": {"type": ["string", "null"]},
    "status": {"type": "string"},
    "progress_stage": {"type": "string"},
    "progress_fraction": {"type": "number"},
    "queue_position": {"type": ["number", "null"]},
    "runner_id": {"type": ["string", "null"]},
    "attempt": {"type": "number"},
    "status_reason": {"type": ["string", "null"]},
    "interrupted_at": {"type": ["string", "null"]},
    "recovered_at": {"type": ["string", "null"]},
    "recovery_action": {"type": ["string", "null"]},
    "superseded_by": {"type": ["string", "null"]},
    "process_metadata": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["pid", "started_at", "command", "cwd"],
      "properties": {
        "pid": {"type": ["number", "null"]},
        "started_at": {"type": ["string", "null"]},
        "command": {"type": ["string", "null"]},
        "cwd": {"type": ["string", "null"]}
      }
    },
    "artifact_reconciliation": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["status", "details"],
      "properties": {
        "status": {"type": "string"},
        "details": {"type": "array", "items": {"type": "string"}}
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "message"],
        "additionalProperties": false,
        "properties": {
          "code": {"type": "string"},
          "message": {"type": "string"}
        }
      }
    },
    "parallel_execution_requested": {"type": "boolean"},
    "parallel_execution_granted": {"type": "boolean"},
    "parallel_fallback_reason": {"type": ["string", "null"]},
    "workspace_path": {"type": ["string", "null"]},
    "branch_name": {"type": ["string", "null"]},
    "dependency_blocker_fingerprint": {"type": ["string", "null"]},
    "handoff_blocker_fingerprint": {"type": ["string", "null"]},
    "current_activity": {"type": ["string", "null"]},
    "prompt_path": {"type": ["string", "null"]},
    "stdout_path": {"type": ["string", "null"]},
    "stderr_path": {"type": ["string", "null"]},
    "output_path": {"type": ["string", "null"]},
    "dependency_blockers": {"type": "array", "items": {"type": "string"}},
    "started_at": {"type": "string"},
    "updated_at": {"type": "string"},
    "latest_event": {
      "type": ["object", "null"],
      "required": ["timestamp", "event_type", "message"],
      "additionalProperties": false,
      "properties": {
        "timestamp": {"type": "string"},
        "event_type": {"type": "string"},
        "message": {"type": "string"}
      }
    }
  }
}
