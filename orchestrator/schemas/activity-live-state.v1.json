{
  "type": "object",
  "required": [
    "schema",
    "run_id",
    "activity_id",
    "kind",
    "entity_id",
    "phase",
    "objective_id",
    "display_name",
    "assigned_role",
    "status",
    "progress_stage",
    "progress_fraction",
    "queue_position",
    "runner_id",
    "warnings",
    "parallel_execution_requested",
    "parallel_execution_granted",
    "parallel_fallback_reason",
    "workspace_path",
    "branch_name",
    "dependency_blocker_fingerprint",
    "handoff_blocker_fingerprint",
    "attempt",
    "status_reason",
    "interrupted_at",
    "recovered_at",
    "recovery_action",
    "superseded_by",
    "process_metadata",
    "artifact_reconciliation",
    "current_activity",
    "prompt_path",
    "stdout_path",
    "stderr_path",
    "output_path",
    "dependency_blockers",
    "started_at",
    "updated_at",
    "latest_event"
