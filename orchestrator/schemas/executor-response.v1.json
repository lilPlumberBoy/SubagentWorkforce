{
  "type": "object",
  "required": [
    "summary",
    "status",
    "artifacts",
    "validation_results",
    "open_issues",
    "produced_output_ids",
    "blockers",
    "change_requests",
    "collaboration_request"
  ],
  "additionalProperties": false,
  "properties": {
    "summary": {"type": "string"},
    "status": {"type": "string", "enum": ["ready_for_bundle_review", "blocked", "needs_revision"]},
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "status"],
        "additionalProperties": false,
        "properties": {
          "path": {"type": "string"},
          "status": {"type": "string"}
        }
      }
    },
    "validation_results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "status", "evidence"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string"},
          "status": {"type": "string", "enum": ["passed", "failed"]},
          "evidence": {"type": "string"}
        }
      }
    },
    "open_issues": {"type": "array", "items": {"type": "string"}},
    "blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "summary", "details", "related_paths", "related_validation_ids", "suggested_owner_capability"],
        "additionalProperties": false,
        "properties": {
          "kind": {"type": "string"},
          "summary": {"type": "string"},
          "details": {"type": "string"},
          "related_paths": {"type": "array", "items": {"type": "string"}},
          "related_validation_ids": {"type": "array", "items": {"type": "string"}},
          "suggested_owner_capability": {"type": ["string", "null"]}
        }
      }
    },
    "change_requests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "change_category",
          "summary",
          "blocking_reason",
          "why_local_resolution_is_invalid",
          "blocking",
          "goal_critical",
          "affected_output_ids",
          "affected_handoff_ids",
          "impacted_objective_ids",
          "impacted_task_ids",
          "required_reentry_phase",
          "impact"
        ],
        "additionalProperties": false,
        "properties": {
          "change_category": {
            "type": "string",
            "enum": ["interface_contract", "shared_behavior", "ownership_boundary", "acceptance_rule"]
          },
          "summary": {"type": "string"},
          "blocking_reason": {"type": "string"},
          "why_local_resolution_is_invalid": {"type": "string"},
          "blocking": {"type": "boolean"},
          "goal_critical": {"type": "boolean"},
          "affected_output_ids": {"type": "array", "items": {"type": "string"}},
          "affected_handoff_ids": {"type": "array", "items": {"type": "string"}},
          "impacted_objective_ids": {"type": "array", "items": {"type": "string"}},
          "impacted_task_ids": {"type": "array", "items": {"type": "string"}},
          "required_reentry_phase": {"type": "string", "enum": ["discovery", "design", "mvp-build", "polish"]},
          "impact": {
            "type": "object",
            "required": [
              "goal_changed",
              "scope_changed",
              "boundary_changed",
              "interface_changed",
              "architecture_changed",
              "team_changed",
              "implementation_changed"
            ],
            "additionalProperties": false,
            "properties": {
              "goal_changed": {"type": "boolean"},
              "scope_changed": {"type": "boolean"},
              "boundary_changed": {"type": "boolean"},
              "interface_changed": {"type": "boolean"},
              "architecture_changed": {"type": "boolean"},
              "team_changed": {"type": "boolean"},
              "implementation_changed": {"type": "boolean"}
            }
          }
        }
      }
    },
    "produced_output_ids": {"type": "array", "items": {"type": "string"}},
    "collaboration_request": {
      "type": ["object", "null"],
      "required": ["to_role", "type", "summary", "blocking"],
      "additionalProperties": false,
      "properties": {
        "to_role": {"type": "string"},
        "type": {"type": "string"},
        "summary": {"type": "string"},
        "blocking": {"type": "boolean"}
      }
    }
  }
}
