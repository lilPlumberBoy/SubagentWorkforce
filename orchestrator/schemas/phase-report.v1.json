{
  "type": "object",
  "required": [
    "schema",
    "run_id",
    "phase",
    "summary",
    "objective_outcomes",
    "accepted_bundles",
    "unresolved_risks",
    "parallelism_summary",
    "collaboration_summary",
    "observability_summary",
    "recovery_summary",
    "release_validation_summary",
    "proposed_role_changes",
    "recommendation",
    "human_approved"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": {"type": "string", "enum": ["phase-report.v1"]},
    "run_id": {"type": "string"},
    "phase": {"type": "string", "enum": ["discovery", "design", "mvp-build", "polish"]},
    "summary": {"type": "string"},
    "objective_outcomes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["objective_id", "status", "accepted_bundles"],
        "additionalProperties": false,
        "properties": {
          "objective_id": {"type": "string"},
          "status": {"type": "string", "enum": ["accepted", "pending", "blocked"]},
          "accepted_bundles": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "accepted_bundles": {"type": "array", "items": {"type": "string"}},
    "unresolved_risks": {"type": "array", "items": {"type": "string"}},
    "parallelism_summary": {
      "type": "object",
      "required": [
        "total_tasks_considered",
        "tasks_run_in_parallel",
        "tasks_serialized_by_policy",
        "tasks_serialized_by_runtime_conflict",
        "incidents"
      ],
      "additionalProperties": false,
      "properties": {
        "total_tasks_considered": {"type": "number"},
        "tasks_run_in_parallel": {"type": "number"},
        "tasks_serialized_by_policy": {"type": "number"},
        "tasks_serialized_by_runtime_conflict": {"type": "number"},
        "incidents": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["task_id", "reason", "artifact_path"],
            "additionalProperties": false,
            "properties": {
              "task_id": {"type": "string"},
              "reason": {"type": "string"},
              "artifact_path": {"type": "string"}
            }
          }
        }
      }
    },
    "collaboration_summary": {
      "type": "object",
      "required": [
        "total_handoffs",
        "blocking_handoffs",
        "satisfied_handoffs",
        "pending_handoffs",
        "blocked_handoffs",
        "handoffs_by_objective",
        "incidents"
      ],
      "additionalProperties": false,
      "properties": {
        "total_handoffs": {"type": "number"},
        "blocking_handoffs": {"type": "number"},
        "satisfied_handoffs": {"type": "number"},
        "pending_handoffs": {"type": "number"},
        "blocked_handoffs": {"type": "number"},
        "handoffs_by_objective": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "objective_id",
              "total_handoffs",
              "blocking_handoffs",
              "satisfied_handoffs",
              "pending_handoffs",
              "blocked_handoffs",
              "handoff_ids"
            ],
            "additionalProperties": false,
            "properties": {
              "objective_id": {"type": "string"},
              "total_handoffs": {"type": "number"},
              "blocking_handoffs": {"type": "number"},
              "satisfied_handoffs": {"type": "number"},
              "pending_handoffs": {"type": "number"},
              "blocked_handoffs": {"type": "number"},
              "handoff_ids": {"type": "array", "items": {"type": "string"}}
            }
          }
        },
        "incidents": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["handoff_id", "status", "reason", "artifact_path"],
            "additionalProperties": false,
            "properties": {
              "handoff_id": {"type": "string"},
              "status": {"type": "string"},
              "reason": {"type": "string"},
              "artifact_path": {"type": "string"},
              "objective_id": {"type": "string"},
              "consumer_task_ids": {"type": "array", "items": {"type": "string"}}
            }
          }
        }
      }
    },
    "observability_summary": {
      "type": "object",
      "required": [
        "total_calls",
        "completed_calls",
        "failed_calls",
        "timed_out_calls",
        "retry_scheduled_calls",
        "total_input_tokens",
        "total_cached_input_tokens",
        "total_output_tokens",
        "total_prompt_chars",
        "total_prompt_lines",
        "average_latency_ms",
        "max_latency_ms",
        "average_queue_wait_ms"
      ],
      "additionalProperties": false,
      "properties": {
        "total_calls": {"type": "number"},
        "completed_calls": {"type": "number"},
        "failed_calls": {"type": "number"},
        "timed_out_calls": {"type": "number"},
        "retry_scheduled_calls": {"type": "number"},
        "total_input_tokens": {"type": "number"},
        "total_cached_input_tokens": {"type": "number"},
        "total_output_tokens": {"type": "number"},
        "total_prompt_chars": {"type": "number"},
        "total_prompt_lines": {"type": "number"},
        "average_latency_ms": {"type": "number"},
        "max_latency_ms": {"type": "number"},
        "average_queue_wait_ms": {"type": "number"}
      }
    },
    "recovery_summary": {
      "type": "object",
      "required": [
        "interrupted_activities",
        "recovered_activities",
        "abandoned_attempts",
        "incidents"
      ],
      "additionalProperties": false,
      "properties": {
        "interrupted_activities": {"type": "number"},
        "recovered_activities": {"type": "number"},
        "abandoned_attempts": {"type": "number"},
        "incidents": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["activity_id", "status", "reason"],
            "additionalProperties": false,
            "properties": {
              "activity_id": {"type": "string"},
              "status": {"type": "string"},
              "reason": {"type": "string"},
              "artifact_path": {"type": "string"}
            }
          }
        }
      }
    },
    "release_validation_summary": {
      "type": ["object", "null"],
      "required": [
        "status",
        "command",
        "working_directory",
        "report_path",
        "stdout_path",
        "stderr_path",
        "summary"
      ],
      "additionalProperties": false,
      "properties": {
        "status": {"type": "string", "enum": ["passed", "failed"]},
        "command": {"type": ["string", "null"]},
        "working_directory": {"type": "string"},
        "report_path": {"type": "string"},
        "stdout_path": {"type": "string"},
        "stderr_path": {"type": "string"},
        "summary": {"type": "string"},
        "failure_diagnostics": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "category",
              "owner_capability",
              "owner_objective_id",
              "source_test",
              "paths",
              "excerpt",
              "repairable"
            ],
            "additionalProperties": false,
            "properties": {
              "category": {"type": "string"},
              "owner_capability": {"type": ["string", "null"]},
              "owner_objective_id": {"type": ["string", "null"]},
              "source_test": {"type": ["string", "null"]},
              "paths": {"type": "array", "items": {"type": "string"}},
              "excerpt": {"type": "string"},
              "repairable": {"type": "boolean"}
            }
          }
        }
      }
    },
    "proposed_role_changes": {"type": "array", "items": {"type": "string"}},
    "recommendation": {"type": "string", "enum": ["advance", "hold"]},
    "human_approved": {"type": "boolean"}
  }
}
