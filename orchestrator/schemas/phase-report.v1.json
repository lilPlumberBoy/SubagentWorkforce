{
  "type": "object",
  "required": [
    "schema",
    "run_id",
    "phase",
    "summary",
    "objective_outcomes",
    "accepted_bundles",
    "unresolved_risks",
    "parallelism_summary",
    "collaboration_summary",
    "recovery_summary",
    "proposed_role_changes",
    "recommendation",
    "human_approved"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": {"type": "string", "enum": ["phase-report.v1"]},
    "run_id": {"type": "string"},
    "phase": {"type": "string", "enum": ["discovery", "design", "mvp-build", "polish"]},
    "summary": {"type": "string"},
    "objective_outcomes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["objective_id", "status", "accepted_bundles"],
        "additionalProperties": false,
        "properties": {
          "objective_id": {"type": "string"},
          "status": {"type": "string", "enum": ["accepted", "pending", "blocked"]},
          "accepted_bundles": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "accepted_bundles": {"type": "array", "items": {"type": "string"}},
    "unresolved_risks": {"type": "array", "items": {"type": "string"}},
    "parallelism_summary": {
      "type": "object",
      "required": [
        "total_tasks_considered",
        "tasks_run_in_parallel",
        "tasks_serialized_by_policy",
        "tasks_serialized_by_runtime_conflict",
        "incidents"
      ],
      "additionalProperties": false,
      "properties": {
        "total_tasks_considered": {"type": "number"},
        "tasks_run_in_parallel": {"type": "number"},
        "tasks_serialized_by_policy": {"type": "number"},
        "tasks_serialized_by_runtime_conflict": {"type": "number"},
        "incidents": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["task_id", "reason", "artifact_path"],
            "additionalProperties": false,
            "properties": {
              "task_id": {"type": "string"},
              "reason": {"type": "string"},
              "artifact_path": {"type": "string"}
            }
          }
        }
      }
    },
    "collaboration_summary": {
      "type": "object",
      "required": [
        "total_handoffs",
        "blocking_handoffs",
        "satisfied_handoffs",
        "pending_handoffs",
        "blocked_handoffs",
        "handoffs_by_objective",
        "incidents"
      ],
      "additionalProperties": false,
      "properties": {
        "total_handoffs": {"type": "number"},
        "blocking_handoffs": {"type": "number"},
        "satisfied_handoffs": {"type": "number"},
        "pending_handoffs": {"type": "number"},
        "blocked_handoffs": {"type": "number"},
        "handoffs_by_objective": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "objective_id",
              "total_handoffs",
              "blocking_handoffs",
              "satisfied_handoffs",
              "pending_handoffs",
              "blocked_handoffs",
              "handoff_ids"
            ],
            "additionalProperties": false,
            "properties": {
              "objective_id": {"type": "string"},
              "total_handoffs": {"type": "number"},
              "blocking_handoffs": {"type": "number"},
              "satisfied_handoffs": {"type": "number"},
              "pending_handoffs": {"type": "number"},
              "blocked_handoffs": {"type": "number"},
              "handoff_ids": {"type": "array", "items": {"type": "string"}}
            }
          }
        },
        "incidents": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["handoff_id", "status", "reason", "artifact_path"],
            "additionalProperties": false,
            "properties": {
              "handoff_id": {"type": "string"},
              "status": {"type": "string"},
              "reason": {"type": "string"},
              "artifact_path": {"type": "string"},
              "objective_id": {"type": "string"},
              "consumer_task_ids": {"type": "array", "items": {"type": "string"}}
            }
          }
        }
      }
    },
    "recovery_summary": {
      "type": "object",
      "required": [
        "interrupted_activities",
        "recovered_activities",
        "abandoned_attempts",
        "incidents"
      ],
      "additionalProperties": false,
      "properties": {
        "interrupted_activities": {"type": "number"},
        "recovered_activities": {"type": "number"},
        "abandoned_attempts": {"type": "number"},
        "incidents": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["activity_id", "status", "reason"],
            "additionalProperties": false,
            "properties": {
              "activity_id": {"type": "string"},
              "status": {"type": "string"},
              "reason": {"type": "string"},
              "artifact_path": {"type": "string"}
            }
          }
        }
      }
    },
    "proposed_role_changes": {"type": "array", "items": {"type": "string"}},
    "recommendation": {"type": "string", "enum": ["advance", "hold"]},
    "human_approved": {"type": "boolean"}
  }
}
